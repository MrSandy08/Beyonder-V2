{
  "name": "beyonder-bot",
  "version": "2.1.0",
  "description": "Beyonder — Bot de WhatsApp para grupos de roleplay con IA, moderación y sistema de personajes",
  "main": "bot.js",
  "scripts": {
    "start": "node bot.js",
    "dev": "node --watch bot.js",
    "test": "jest --testPathPattern=tests/ --forceExit",
    "test:coverage": "jest --testPathPattern=tests/ --coverage --forceExit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@gradio/client": "^1.6.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.9",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "mongoose": "^8.4.1",
    "pino": "^9.2.0",
    "qrcode-terminal": "^0.12.0",
    "wa-sticker-formatter": "^4.0.3"
  },
  "devDependencies": {
    "axios-mock-adapter": "^1.22.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  },
  "keywords": [
    "whatsapp",
    "bot",
    "baileys",
    "roleplay",
    "moderacion",
    "ollama",
    "gradio",
    "ia"
